{
  "files.encoding": "utf8",
  "files.autoGuessEncoding": false,
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": false,
  "terminal.integrated.defaultProfile": "PowerShell",
  "terminal.integrated.profiles": {
    "PowerShell": {
      "source": "PowerShell",
      "path": "pwsh.exe",
      "args": ["-NoLogo"]
    }
  },
  "[html]": {
    "files.encoding": "utf8"
  },
  "[css]": {
    "files.encoding": "utf8"
  },
  "[javascript]": {
    "files.encoding": "utf8"
  }
}
